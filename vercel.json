{
  "buildCommand": "pnpm --filter @workspace/lightspeed-ghost run build",
  "outputDirectory": "artifacts/lightspeed-ghost/dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "rewrites": [
    { "source": "/seo/:path*", "destination": "https://lightspeedghost-5szz.onrender.com/seo/:path*" },
    { "source": "/seo-sitemap.xml", "destination": "https://lightspeedghost-5szz.onrender.com/sitemap.xml" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/((?!assets/).*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    }
  ]
}
