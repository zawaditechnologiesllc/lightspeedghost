# ─────────────────────────────────────────────
# Light Speed Ghost — Frontend Environment Vars
# Copy this to .env.local for local dev, then
# add each key to Vercel → Settings → Environment Variables
# ─────────────────────────────────────────────

# URL of your deployed Render backend (no trailing slash)
# Example: https://lightspeedghost-api.onrender.com
VITE_API_URL=https://your-render-api-url.onrender.com
