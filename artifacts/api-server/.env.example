# ─────────────────────────────────────────────────────────────
# Light Speed Ghost — API Server Environment Variables
# Set all of these in Render → Environment when deploying
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string (Supabase direct connection URL)
# Supabase → Project Settings → Database → Direct connection → URI
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Runtime environment
NODE_ENV=production

# Render assigns PORT automatically — leave this unset in Render,
# it will be injected at runtime
# PORT=8080

# Random secret for session signing (Render can auto-generate this)
# Generate one: openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-string

# Comma-separated list of allowed frontend origins (your Vercel domain)
# Example: https://lightspeedghost.com,https://www.lightspeedghost.com
ALLOWED_ORIGINS=https://lightspeedghost.com,https://www.lightspeedghost.com

# ── SEO Engine ────────────────────────────────────────────────────────────────
# Google AI Studio API key (Gemini 2.5 Flash — primary LLM for SEO page generation)
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# SEO budget cap per month in USD (default: 8.00)
SEO_BUDGET_LIMIT=8.00

# Max pages per batch generation run (default: 30)
SEO_DAILY_PAGE_LIMIT=30

# Minimum word count per SEO page (default: 800)
SEO_MIN_WORD_COUNT=800
